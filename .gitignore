cat > .gitignore <<'EOF'
.DS_Store

# Env files
.env
.env.*

# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Build outputs
dist/
build/
*.tsbuildinfo

# Evidence images
api-gateway/public/evidence/
api-gateway/public/evidence/**

# Fabric secrets / crypto materials
**/organizations/
**/wallet/
**/*.pem
**/*_sk
**/keystore/
**/signcerts/

# IDE
.vscode/
EOF
