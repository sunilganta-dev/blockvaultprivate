# Block Vault Systems — Camera Service Environment
# Copy to /home/ubuntu/camera-service/.env on the VM
# DO NOT commit the filled-in version

# Camera 1 — Location A (via ngrok or Cloudflare Tunnel)
CAM_1_ID=axis-cam-1
CAM_1_URL=https://<CAM1_TUNNEL_DOMAIN>/mjpg/video.mjpg?fps=25
CAM_1_USER=root
CAM_1_PASS=<CAMERA_1_PASSWORD>

# Camera 2 — Location B (via ngrok or Cloudflare Tunnel)
CAM_2_ID=axis-cam-2
CAM_2_URL=https://<CAM2_TUNNEL_DOMAIN>/mjpg/video.mjpg?fps=25
CAM_2_USER=root
CAM_2_PASS=<CAMERA_2_PASSWORD>

# Service port
HTTP_PORT=5600
